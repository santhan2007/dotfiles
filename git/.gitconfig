[user]
	name = santhan2007
	email = santhansumedh2007@gmail.com
[init]
	defaultBranch = main
[core]
	autocrlf = input
	pager = delta
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
	dark = true
	line-numbers = true
[merge]
	conflictStyle = zdiff3
[pull]
	rebase = true
[alias]
	# git shortcuts
	st = status
	co = checkout
	br = branch
	ci = commit
	lg = log --oneline --graph --decorate --all
	last = log -1 --stat
	unstage = reset HEAD --
	df = diff
	dfs = diff --staged
	# hacker aliases
	sweep = "!git branch --merged | grep -v '\\*\\|main\\|master' | xargs -n 1 git branch -d"
	undo = reset --soft HEAD~1
[diff]
	tool = delta
[diff "delta"]
	options = --dark --line-numbers
